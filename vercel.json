{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "rewrites": [
    {
      "source": "/",
      "destination": "/web/index.html"
    },
    {
      "source": "/app.js",
      "destination": "/web/app.js"
    },
    {
      "source": "/app.css",
      "destination": "/web/app.css"
    }
  ],
  "functions": {
    "api/*.py": {
      "maxDuration": 60,
      "excludeFiles": "{samples/**,output/**,__pycache__/**,web/**,*.pyc,.DS_Store}"
    }
  }
}
